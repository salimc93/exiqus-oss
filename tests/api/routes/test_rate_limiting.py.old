            recent_commits=[],
            file_structure=[],
            readme_content="# Test Repo",
            metrics=mock_metrics,
            fetched_at=datetime.now(timezone.utc),
            is_private=False,
            is_fork=False,
            is_archived=False,
            is_disabled=False,
        )

        mock_fetcher.fetch_repository_data.return_value = mock_repo_data

        return mock_fetcher

    @pytest.fixture
    def mock_redis_service(self):
        """Create mock Redis service for testing."""
        mock_redis = AsyncMock()
        # Initialize counters
        self.counters = {}

        async def mock_get(key):
            return self.counters.get(key, "0")

        async def mock_incr(key):
            current = int(self.counters.get(key, 0))
            self.counters[key] = str(current + 1)
            return current + 1

        async def mock_decr(key):
            current = int(self.counters.get(key, 0))
            self.counters[key] = str(max(0, current - 1))
            return max(0, current - 1)

        async def mock_set(key, value):
            self.counters[key] = value
            return True

        async def mock_expire(key, ttl):
            return True

        mock_redis.get = mock_get
        mock_redis.incr = mock_incr
        mock_redis.decr = mock_decr
        mock_redis.set = mock_set
        mock_redis.expire = mock_expire
        mock_redis.counters = self.counters  # Expose counters for test access

        return mock_redis

    @pytest.mark.asyncio
    async def test_single_request_allowed(self, client):
        """Test that a single request is allowed."""
        with patch("github_analyzer.api.routes.analysis.redis_service") as mock_redis:
            # Create async function that returns None
            async def async_get(key):
                return None

            mock_redis.get = async_get

            # Mock the analysis function
            with patch(
                "github_analyzer.api.routes.analysis._perform_repository_analysis"
            ) as mock_perform:
                from github_analyzer.api.models.responses import AnalysisResponse

                mock_perform.return_value = AnalysisResponse(
                    repository_url="https://github.com/user/test-repo",
                    context="general",
                    analysis={
                        "executive_summary": "Test summary",
                        "overall_recommendation": "HIRE",
                        "confidence_score": 85,
                        "repository_type": "production",
                        "context_fit_score": 80,
                        "key_strengths": ["Good code quality"],
                        "primary_concerns": [],
                        "hiring_recommendations": ["Proceed with interview"],
                        "interview_focus_areas": ["System design"],
                    },
                    metadata={
                        "analysis_id": "test_123",
                        "repository_type": "production",
                        "confidence_grade": "B",
                        "ai_analysis_used": False,
                        "analysis_cost_usd": 0.0,
                        "response_time_seconds": 1.5,
                        "timestamp": "2024-01-01T12:00:00Z",
                        "cached": False,
                        "data_completeness": 0.9,
                    },
                )

                response = await client.post(
                    "/api/v1/analyze",
                    json={
                        "repository_url": "https://github.com/user/test-repo",
                        "context": "general",
                    },
                )

                assert response.status_code == 200

    @pytest.mark.asyncio
    async def test_user_concurrent_limit_exceeded(self, client, mock_redis_service):
        """Test that user concurrent limit is enforced."""
        # Set user counter to max (3)
        mock_redis_service.counters["rate_limit:user:test_user_123"] = "3"

        response = await client.post(
            "/api/v1/analyze",
            json={
                "repository_url": "https://github.com/user/test-repo",
                "context": "general",
            },
        )

        assert response.status_code == 429
        data = response.json()
        assert "Too many concurrent requests" in data["detail"]["error"]
        assert "user_concurrent" in data["detail"]

    @pytest.mark.asyncio
    async def test_global_concurrent_limit_exceeded(self, client, mock_redis_service):
        """Test that global concurrent limit is enforced."""
        # Set global counter to max (10)
        mock_redis_service.counters["rate_limit:global"] = "10"

        response = await client.post(
            "/api/v1/analyze",
            json={
                "repository_url": "https://github.com/user/test-repo",
                "context": "general",
            },
        )

        assert response.status_code == 429
        data = response.json()
        assert "System at capacity" in data["detail"]["error"]
        assert "global_concurrent" in data["detail"]

    @pytest.mark.asyncio
    async def test_concurrent_requests_release_on_completion(
        self, client, mock_redis_service
    ):
        """Test that rate limit slots are released after request completion."""
        # Start with empty counters
        mock_redis_service.counters = {}

        with patch("github_analyzer.api.routes.analysis.redis_service") as mock_redis:

            async def async_get(key):
                return None

            mock_redis.get = async_get

            # Mock the analysis function to be slow
            with patch(
                "github_analyzer.api.routes.analysis._perform_repository_analysis"
            ) as mock_perform:
                from github_analyzer.api.models.responses import AnalysisResponse

                async def slow_analysis(*args, **kwargs):
                    await asyncio.sleep(0.1)  # Simulate work
                    return AnalysisResponse(
                        repository_url="https://github.com/user/test-repo",
                        context="general",
                        analysis={
                            "executive_summary": "Test summary",
                            "overall_recommendation": "HIRE",
                            "confidence_score": 85,
                            "repository_type": "production",
                            "context_fit_score": 80,
                            "key_strengths": ["Good code quality"],
                            "primary_concerns": [],
                            "hiring_recommendations": ["Proceed with interview"],
                            "interview_focus_areas": ["System design"],
                        },
                        metadata={
                            "analysis_id": "test_123",
                            "repository_type": "production",
                            "confidence_grade": "B",
                            "ai_analysis_used": False,
                            "analysis_cost_usd": 0.0,
                            "response_time_seconds": 1.5,
                            "timestamp": "2024-01-01T12:00:00Z",
                            "cached": False,
                            "data_completeness": 0.9,
                        },
                    )

                mock_perform.side_effect = slow_analysis

                # Make a request
                response = await client.post(
                    "/api/v1/analyze",
                    json={
                        "repository_url": "https://github.com/user/test-repo",
                        "context": "general",
                    },
                )

                assert response.status_code == 200

                # Check that counters were decremented (released)
                # In a real implementation, the context manager would handle this
                # For testing, we verify the final state

    @pytest.mark.asyncio
    async def test_multiple_users_different_limits(
        self, app, mock_github_fetcher, mock_redis_service
    ):
        """Test that different users have separate rate limits."""
        from github_analyzer.api.auth.dependencies import require_api_access
        from github_analyzer.api.dependencies import (
            get_github_fetcher,
            get_redis_service,
        )
        from github_analyzer.api.services.rate_limit_dependencies import (
            get_rate_limit_service,
        )
        from github_analyzer.api.services.rate_limit_service import RateLimitService

        # Create our own rate limit service with the mock redis
        test_rate_limit_service = RateLimitService(mock_redis_service)

        # Set up the app with our controlled mocks
        app.dependency_overrides[get_redis_service] = lambda: mock_redis_service
        app.dependency_overrides[get_github_fetcher] = lambda: mock_github_fetcher
        app.dependency_overrides[get_rate_limit_service] = (
            lambda: test_rate_limit_service
        )

        # Create test client
        async with AsyncClient(
            transport=ASGITransport(app=app), base_url="http://test"
        ) as client:
            # Mock the Redis cache for analysis results
            with patch(
                "github_analyzer.api.routes.analysis.redis_service"
            ) as mock_cache:

                async def async_get(key):
                    return None  # No cache hits

                mock_cache.get = async_get

                # Mock analysis to avoid hitting real services
                with patch(
                    "github_analyzer.api.routes.analysis._perform_repository_analysis"
                ) as mock_perform:
                    import asyncio

                    from github_analyzer.api.models.responses import AnalysisResponse

                    # Event to control when analysis completes
                    analysis_complete = asyncio.Event()

                    async def mock_analysis(*args, **kwargs):
                        # Wait until we signal completion
                        await analysis_complete.wait()
                        return AnalysisResponse(
                            repository_url=args[0],
                            context="general",
                            analysis={
                                "executive_summary": "Test",
                                "overall_recommendation": "HIRE",
                                "confidence_score": 85,
                                "repository_type": "portfolio",
                                "context_fit_score": 80,
                                "key_strengths": ["Good"],
                                "primary_concerns": [],
                                "hiring_recommendations": ["Yes"],
                                "interview_focus_areas": ["Tech"],
                            },
                            metadata={
                                "analysis_id": "test_123",
                                "repository_type": "portfolio",
                                "confidence_grade": "B",
                                "ai_analysis_used": False,
                                "analysis_cost_usd": 0.0,
                                "response_time_seconds": 0.1,
                                "timestamp": "2024-01-01T12:00:00Z",
                                "cached": False,
                                "data_completeness": 0.9,
                            },
                        )

                    mock_perform.side_effect = mock_analysis

                    # Test User 1: Concurrent limit
                    app.dependency_overrides[require_api_access] = lambda: "user1"

                    # Start 3 concurrent requests (don't await them yet)
                    tasks = []
                    for i in range(3):
                        task = asyncio.create_task(
                            client.post(
                                "/api/v1/analyze",
                                json={
                                    "repository_url": f"https://github.com/user/repo{i+1}",
                                    "context": "general",
                                },
                            )
                        )
                        tasks.append(task)

                    # Give tasks time to acquire rate limit slots
                    await asyncio.sleep(0.1)

                    # Check Redis state - user1 should have 3 concurrent requests
                    user1_count = await mock_redis_service.get("rate_limit:user:user1")
                    assert user1_count == "3", f"Expected '3' but got '{user1_count}'"

                    # User1's 4th request should be blocked
                    response4 = await client.post(
                        "/api/v1/analyze",
                        json={
                            "repository_url": "https://github.com/user/repo4",
                            "context": "general",
                        },
                    )
                    assert response4.status_code == 429
                    assert (
                        "Too many concurrent requests"
                        in response4.json()["detail"]["error"]
                    )

                    # Test User 2: Has separate limit
                    app.dependency_overrides[require_api_access] = lambda: "user2"

                    # User2 should be able to make a request
                    task_user2 = asyncio.create_task(
                        client.post(
                            "/api/v1/analyze",
                            json={
                                "repository_url": "https://github.com/user/repo_user2",
                                "context": "general",
                            },
                        )
                    )

                    # Give task time to acquire rate limit slot
                    await asyncio.sleep(0.1)

                    # Check Redis state - user2 should have 1 concurrent request
                    user2_count = await mock_redis_service.get("rate_limit:user:user2")
                    assert user2_count == "1"

                    # User1 should still be blocked
                    app.dependency_overrides[require_api_access] = lambda: "user1"
                    response5 = await client.post(
                        "/api/v1/analyze",
                        json={
                            "repository_url": "https://github.com/user/repo5",
                            "context": "general",
                        },
                    )
                    assert response5.status_code == 429

                    # Complete all analysis tasks
                    analysis_complete.set()

                    # Wait for all tasks to complete
                    results = await asyncio.gather(*tasks, task_user2)
                    for result in results:
                        assert result.status_code == 200
