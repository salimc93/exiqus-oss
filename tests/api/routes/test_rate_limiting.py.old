            description="Test repository",
            created_at=datetime.now(timezone.utc),
            updated_at=datetime.now(timezone.utc),
            pushed_at=datetime.now(timezone.utc),
            default_branch="main",
            size=1000,
            languages={"Python": 50000, "JavaScript": 25000},
            topics=[],
            license_name="MIT",
            stars=10,
            forks=2,
            watchers=5,
            open_issues=3,
            has_readme=True,
            has_license=True,
            has_contributing=False,
            has_tests=True,
