        mock_metrics = RepositoryMetrics(
            total_commits=50,
            unique_contributors=5,
            lines_of_code=1000,
            test_coverage_estimate=0.7,
            documentation_ratio=0.3,
            days_since_last_commit=7,
            commit_frequency=2.5,
            avg_commit_size=150.0,
