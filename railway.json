{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.railway"
  },
  "deploy": {
    "healthcheckPath": "/api/v1/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "services": ["exiqus-api"]
  },
  "environments": {
    "production": {
      "build": {
        "dockerfilePath": "Dockerfile.railway"
      },
      "services": ["exiqus-api"]
    },
    "staging": {
      "build": {
        "dockerfilePath": "Dockerfile.railway"
      },
      "services": ["exiqus-api"]
    }
  },
  "service": "exiqus-api"
}