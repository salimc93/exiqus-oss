# Backend API URL (defaults to http://localhost:8000 if unset)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Public site URL used in metadata/sitemaps (defaults to http://localhost:3000)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Note: the admin portal secret is configured on the BACKEND ONLY
# (ADMIN_SECRET env var). Never put secrets in NEXT_PUBLIC_* variables -
# they are shipped to every browser.
