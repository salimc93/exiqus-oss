# Production Environment Configuration for Railway/Deployment
# Copy this to your Railway environment variables

# API Keys (REQUIRED - Add your real keys)
ANTHROPIC_API_KEY=your_production_anthropic_api_key
GITHUB_TOKEN=your_production_github_token

# Stripe API Keys (PRODUCTION MODE)
STRIPE_PUBLISHABLE_KEY=pk_live_your_production_publishable_key
STRIPE_SECRET_KEY=sk_live_your_production_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_production_webhook_secret

# Production Settings
ENVIRONMENT=production
DEBUG=false

# Database (Railway provides DATABASE_URL automatically)
# DATABASE_URL will be set by Railway

# Redis (if using Railway Redis)
# REDIS_URL will be set by Railway Redis add-on

# Security Settings (IMPORTANT: Change these!)
SECRET_KEY=your-production-secret-key-generate-a-strong-one
JWT_SECRET_KEY=your-production-jwt-secret-generate-a-strong-one
ADMIN_SECRET=your-strong-admin-secret-for-panel-access

# CORS Configuration (set to the domains you deploy the frontend on)
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# Railway-specific: Trust proxy for IP extraction
TRUSTED_PROXY=true

# Frontend URL (your domain)
FRONTEND_URL=https://www.example.com

# Backend API URL - Options:
# 1. Use Railway's provided URL: https://your-backend.railway.app
# 2. Or point a subdomain of your own to Railway
API_BASE_URL=https://your-backend.railway.app

# Email Configuration (Resend for production)
EMAIL_BACKEND=resend
RESEND_API_KEY=your_production_resend_api_key

# Rate Limiting (production values)
RATE_LIMIT_ENABLED=true
DEFAULT_RATE_LIMIT=100

# Cost Tracking
MAX_COST_PER_USER_DAILY=1.00
COST_TRACKING_ENABLED=true

# Tier Configuration
# All tier-specific settings (models, token limits, pricing, timeouts) are centralized in:
# src/github_analyzer/core/tier_config.py
# No model or analysis configuration needed here - it's all handled per-tier