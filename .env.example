# Local development configuration.
#
#   cp .env.example .env
#
# Defaults line up with `docker compose up -d postgres redis`, so the only
# values you must fill in are the two API keys below.

# ---------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# https://github.com/settings/tokens - needs public_repo (or repo for
# private repositories) and read:user
GITHUB_TOKEN=your_github_token_here

# ---------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true

# ---------------------------------------------------------------------
# Datastores - these match docker-compose.yml defaults
# ---------------------------------------------------------------------
DATABASE_URL=postgresql://github_analyzer:exiqus_dev_password@localhost:5432/github_analyzer
REDIS_URL=redis://:exiqus_dev_password@localhost:6379/0

# ---------------------------------------------------------------------
# Secrets - fine for local use, generate real ones before deploying
# (python -c "import secrets; print(secrets.token_urlsafe(32))")
# ---------------------------------------------------------------------
SECRET_KEY=local-dev-secret-not-for-production
JWT_SECRET_KEY=local-dev-jwt-secret-not-for-production
ADMIN_SECRET=local-dev-admin-secret

# ---------------------------------------------------------------------
# URLs and CORS
# ---------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------
# Local conveniences
# ---------------------------------------------------------------------
# Prints emails to the console instead of sending them
EMAIL_BACKEND=console
RATE_LIMIT_ENABLED=false
COST_TRACKING_ENABLED=true
MAX_COST_PER_USER_DAILY=10.00

# ---------------------------------------------------------------------
# Billing (optional) - only needed to work on the Stripe integration.
# Use test-mode keys: https://dashboard.stripe.com/test/apikeys
# Leave STRIPE_WEBHOOK_SECRET unset and webhook handling stays disabled;
# it is never treated as "skip signature verification".
# ---------------------------------------------------------------------
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
