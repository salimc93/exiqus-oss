# Environment variables for docker-compose.yml
#
# Copy this file to .env (or pass with `docker compose --env-file`)
# and replace every placeholder with a real value. Never commit the
# resulting file.

# Required API keys
GITHUB_TOKEN=your-github-token
ANTHROPIC_API_KEY=your-anthropic-api-key

# Database (optional for local dev - falls back to exiqus_dev_password;
# ALWAYS set a strong value for anything internet-facing)
POSTGRES_PASSWORD=choose-a-strong-password

# Redis (same dev fallback as above)
REDIS_PASSWORD=choose-a-strong-password

# Application secrets (generate with: openssl rand -hex 32)
SECRET_KEY=generate-a-random-secret
JWT_SECRET_KEY=generate-a-random-secret

# Grafana (optional monitoring stack)
GF_SECURITY_ADMIN_PASSWORD=choose-a-strong-password
